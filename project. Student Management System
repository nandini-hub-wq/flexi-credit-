// Base class storing common details
class Person {
    String name;
    int age;

    Person(String name, int age) {
        this.name = name;
        this.age = age;
    }

    void displayPersonInfo() {
        System.out.println("Name: " + name);
        System.out.println("Age: " + age);
    }
}

// Derived class adding student-specific attributes
class Student extends Person {
    int rollNumber;
    double marks;

    Student(String name, int age, int rollNumber, double marks) {
        super(name, age); // Call base class constructor
        this.rollNumber = rollNumber;
        this.marks = marks;
    }

    void displayStudentInfo() {
        displayPersonInfo();
        System.out.println("Roll Number: " + rollNumber);
        System.out.println("Marks: " + marks);
    }
}

// Extended class for specialization details
class GraduateStudent extends Student {
    String specialization;

    GraduateStudent(String name, int age, int rollNumber, double marks, String specialization) {
        super(name, age, rollNumber, marks); // Call Student constructor
        this.specialization = specialization;
    }

    void displayCompleteInfo() {
        displayStudentInfo();
        System.out.println("Specialization: " + specialization);
    }
}

public class Main {
    public static void main(String[] args) {
        // Creating an object of the most derived class
        GraduateStudent grad = new GraduateStudent("Alice Johnson", 24, 101, 88.5, "Data Science");
        
        System.out.println("--- Complete Student Information ---");
        grad.displayCompleteInfo();
    }
}
